pragma solidity ^0.8.33;

import {Test, console} from "forge-std/Test.sol";
import {MoodNFT} from "../src/MoodNFT.sol";

contract MoodNftTest is Test {
    MoodNFT public moodNft;
    address public USER;

    string public constant SAD_MOOD_IMAGE_URI = "data:image/svg+xml;base64,";
    string public constant HAPPY_MOOD_IMAGE_URI = "data:image/svg+xml;base64,";

    function setUp() public {
        USER = makeAddr("user");
        moodNft = new MoodNFT(SAD_MOOD_IMAGE_URI, HAPPY_MOOD_IMAGE_URI);
    }

    function testMintToken() public {
        vm.prank(USER);
        moodNft.mintToken();

        assertEq(moodNft.ownerOf(0), USER);
        assertEq(moodNft.s_counterId(), 1);

        string memory uri = moodNft.tokenURI(0);
        assertGt(bytes(uri).length, 0);

        console.log(uri);
    }
}